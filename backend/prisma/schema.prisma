generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ManagementType {
  LM
  TP
}

enum DocumentCategory {
  ORDEN_COMPRA
  FACTURA
  DETALLE_TRABAJADORES
  ARCHIVO_GESTION
  CARTA_EXPLICATIVA
  COMPROBANTE_PAGO
  ARCHIVO_AFP
  RESPUESTA_CEN
  PODER
  OTRO
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String?  @unique
  role       String?
  profile    String?
  is_active  Boolean  @default(true)
  phone      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  notes        Note[]
  activities   Activity[]
  uploadedDocs Document[] @relation("UploadedByUser")

  @@map("users")
}

model Mandante {
  id                String    @id @default(cuid())
  name              String    @unique
  owner_name        String?
  email             String?
  phone             String?
  campaign          String?
  active_contract   String?
  end_contract_date DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  last_activity_at  DateTime?

  groups          CompanyGroup[]
  companies       Company[]
  managementLines ManagementLine[]
  managements     Management[]
  lmRecords       LmRecord[]       @relation("MandanteLmRecords")
  tpRecords       TpRecord[]       @relation("MandanteTpRecords")

  @@map("mandantes")
}

model CompanyGroup {
  id                     String         @id @default(cuid())
  mandante_id            String
  group_type             ManagementType
  name                   String
  owner_name             String?
  secondary_email        String?
  campaign               String?
  power_group_company    String?
  associated_groups      String?
  no_email_participation Boolean?       @default(false)
  tag                    String?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  last_activity_at       DateTime?

  mandante        Mandante         @relation(fields: [mandante_id], references: [id], onDelete: Cascade)
  companies       Company[]
  managementLines ManagementLine[]
  managements     Management[]

  @@unique([mandante_id, group_type, name])
  @@index([mandante_id])
  @@index([group_type])
  @@map("company_groups")
}

model Company {
  id                     String    @id @default(cuid())
  mandante_id            String
  group_id               String?
  razon_social           String
  rut                    String    @unique
  owner_name             String?
  email                  String?
  collaborator_1         String?
  collaborator_2         String?
  estimated_amount       Decimal?  @db.Decimal(18, 2)
  currency               String?
  exchange_rate          Decimal?  @db.Decimal(18, 6)
  active_contract_status String?
  contract_end_date      DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  last_activity_at       DateTime?

  mandante    Mandante         @relation(fields: [mandante_id], references: [id], onDelete: Cascade)
  group       CompanyGroup?    @relation(fields: [group_id], references: [id], onDelete: SetNull)
  lines       ManagementLine[]
  managements Management[]
  lmRecords   LmRecord[]       @relation("CompanyLmRecords")
  tpRecords   TpRecord[]       @relation("CompanyTpRecords")

  @@index([mandante_id])
  @@index([group_id])
  @@index([razon_social])
  @@map("companies")
}

model ManagementLine {
  id                      String         @id @default(cuid())
  mandante_id             String
  group_id                String?
  company_id              String
  line_type               ManagementType
  name                    String?
  owner_name              String?
  portal_access           String?
  mes_produccion_2026     String?
  comment                 String?
  estado_contrato_cliente String?
  fecha_termino_contrato  DateTime?
  consulta_cen            String?
  contenido_cen           String?
  respuesta_cen           String?
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt
  last_activity_at        DateTime?

  mandante    Mandante            @relation(fields: [mandante_id], references: [id], onDelete: Cascade)
  group       CompanyGroup?       @relation(fields: [group_id], references: [id], onDelete: SetNull)
  company     Company             @relation(fields: [company_id], references: [id], onDelete: Cascade)
  afps        ManagementLineAfp[]
  managements Management[]
  lmRecords   LmRecord[]          @relation("LineLmRecords")
  tpRecords   TpRecord[]          @relation("LineTpRecords")

  @@index([mandante_id])
  @@index([group_id])
  @@index([company_id])
  @@index([line_type])
  @@map("management_lines")
}

model ManagementLineAfp {
  id             String   @id @default(cuid())
  line_id        String
  afp_name       String
  owner_name     String?
  current_status String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  line        ManagementLine @relation(fields: [line_id], references: [id], onDelete: Cascade)
  managements Management[]
  lmRecords   LmRecord[]     @relation("LineAfpLmRecords")
  tpRecords   TpRecord[]     @relation("LineAfpTpRecords")

  @@unique([line_id, afp_name])
  @@index([line_id])
  @@map("management_line_afps")
}

model Management {
  id              String         @id @default(cuid())
  mandante_id     String
  group_id        String?
  company_id      String
  line_id         String
  line_afp_id     String?
  management_type ManagementType

  owner_name                  String?
  estado_contrato_cliente     String?
  fecha_termino_contrato      DateTime?
  motivo_tipo_exceso          String?
  mes_produccion_2026         String?
  mes_ingreso_solicitud       String?
  entidad                     String?
  envio_afp                   String?
  estado_gestion              String?
  fecha_presentacion_afp      DateTime?
  fecha_ingreso_afp           DateTime?
  fecha_pago_afp              DateTime?
  numero_solicitud            String?
  grupo_empresa               String?
  razon_social                String?
  rut                         String?
  direccion                   String?
  monto_devolucion            Decimal?  @db.Decimal(18, 2)
  monto_pagado                Decimal?  @db.Decimal(18, 2)
  monto_cliente               Decimal?  @db.Decimal(18, 2)
  monto_finanfix_solutions    Decimal?  @db.Decimal(18, 2)
  monto_real_cliente          Decimal?  @db.Decimal(18, 2)
  monto_real_finanfix_solutions Decimal? @db.Decimal(18, 2)
  fee                         Decimal?  @db.Decimal(18, 2)
  banco                       String?
  tipo_cuenta                 String?
  numero_cuenta               String?
  confirmacion_cc             Boolean?  @default(false)
  confirmacion_poder          Boolean?  @default(false)
  acceso_portal               String?
  facturado_finanfix          String?
  facturado_cliente           String?
  fecha_factura_finanfix      DateTime?
  fecha_pago_factura_finanfix DateTime?
  fecha_notificacion_cliente  DateTime?
  numero_factura              String?
  numero_oc                   String?
  fecha_rechazo               DateTime?
  motivo_rechazo              String?
  consulta_cen                String?
  contenido_cen               String?
  respuesta_cen               String?
  estado_trabajador           String?
  comment                     String?
  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @updatedAt
  last_activity_at            DateTime?

  mandante Mandante           @relation(fields: [mandante_id], references: [id], onDelete: Cascade)
  group    CompanyGroup?      @relation(fields: [group_id], references: [id], onDelete: SetNull)
  company  Company            @relation(fields: [company_id], references: [id], onDelete: Cascade)
  line     ManagementLine     @relation(fields: [line_id], references: [id], onDelete: Cascade)
  lineAfp  ManagementLineAfp? @relation(fields: [line_afp_id], references: [id], onDelete: SetNull)

  documents  Document[]
  notes      Note[]
  activities Activity[]
  lmRecord   LmRecord?
  tpRecord   TpRecord?

  @@index([mandante_id])
  @@index([group_id])
  @@index([company_id])
  @@index([line_id])
  @@index([line_afp_id])
  @@index([management_type])
  @@index([estado_gestion])
  @@index([entidad])
  @@index([razon_social])
  @@index([rut])
  @@map("managements")
}

model LmRecord {
  id            String  @id @default(cuid())
  management_id String? @unique
  mandante_id   String?
  company_id    String?
  line_id       String?
  line_afp_id   String?

  lm_group_id        String?
  search_group       String?
  rut                String
  entity             String?
  management_status  String?
  refund_amount      Decimal? @db.Decimal(18, 2)
  confirmation_cc    Boolean? @default(false)
  confirmation_power Boolean? @default(false)
  actual_paid_amount Decimal? @db.Decimal(18, 2)
  excess_type_reason String?
  worker_status      String?
  request_number     String?
  business_name      String?
  bank_name          String?
  account_number     String?
  account_type       String?
  comment            String?
  mandante           String?
  portal_access      String?
  direccion          String?
  confirmation_cc    Boolean? @default(false)
  confirmation_power Boolean? @default(false)

  estado_contrato_cliente     String?
  fecha_termino_contrato      DateTime?
  motivo_tipo_exceso          String?
  mes_produccion_2026         String?
  envio_afp                   String?
  fecha_presentacion_afp      DateTime?
  fecha_ingreso_afp           DateTime?
  fecha_pago_afp              DateTime?
  monto_cliente               Decimal?  @db.Decimal(18, 2)
  fee                         Decimal?  @db.Decimal(18, 2)
  monto_finanfix_solutions    Decimal?  @db.Decimal(18, 2)
  facturado_finanfix          String?
  facturado_cliente           String?
  fecha_factura_finanfix      DateTime?
  fecha_pago_factura_finanfix DateTime?
  numero_factura              String?
  numero_oc                   String?
  fecha_rechazo               DateTime?
  motivo_rechazo              String?
  consulta_cen                String?
  contenido_cen               String?
  respuesta_cen               String?

  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  last_activity_at DateTime?

  management   Management?        @relation(fields: [management_id], references: [id], onDelete: SetNull)
  mandante_rel Mandante?          @relation("MandanteLmRecords", fields: [mandante_id], references: [id], onDelete: SetNull)
  company_rel  Company?           @relation("CompanyLmRecords", fields: [company_id], references: [id], onDelete: SetNull)
  line_rel     ManagementLine?    @relation("LineLmRecords", fields: [line_id], references: [id], onDelete: SetNull)
  line_afp_rel ManagementLineAfp? @relation("LineAfpLmRecords", fields: [line_afp_id], references: [id], onDelete: SetNull)

  @@index([management_id])
  @@index([mandante_id])
  @@index([company_id])
  @@index([line_id])
  @@index([line_afp_id])
  @@index([rut])
  @@index([business_name])
  @@index([entity])
  @@map("lm_records")
}

model TpRecord {
  id            String  @id @default(cuid())
  management_id String? @unique
  mandante_id   String?
  company_id    String?
  line_id       String?
  line_afp_id   String?

  tp_group_id        String?
  search_group       String?
  rut                String?
  entity             String?
  management_status  String?
  actual_paid_amount Decimal? @db.Decimal(18, 2)
  refund_amount      Decimal? @db.Decimal(18, 2)
  worker_status      String?
  request_number     String?
  business_name      String?
  bank_name          String?
  account_number     String?
  account_type       String?
  comment            String?
  mandante           String?
  portal_access      String?
  direccion          String?
  confirmation_cc    Boolean? @default(false)
  confirmation_power Boolean? @default(false)

  estado_contrato_cliente String?
  fecha_termino_contrato  DateTime?
  mes_produccion_2026     String?
  mes_ingreso_solicitud   String?
  acceso_portal           String?
  motivo_tipo_exceso      String?
  envio_afp               String?
  fecha_presentacion_afp  DateTime?
  fecha_ingreso_afp       DateTime?
  fecha_pago_afp          DateTime?
  monto_cliente           Decimal? @db.Decimal(18, 2)
  fee                     Decimal? @db.Decimal(18, 2)
  monto_finanfix_solutions Decimal? @db.Decimal(18, 2)
  monto_real_cliente      Decimal? @db.Decimal(18, 2)
  monto_real_finanfix_solutions Decimal? @db.Decimal(18, 2)
  facturado_finanfix      String?
  facturado_cliente       String?
  fecha_factura_finanfix  DateTime?
  fecha_pago_factura_finanfix DateTime?
  fecha_notificacion_cliente DateTime?
  numero_factura          String?
  numero_oc               String?
  fecha_rechazo           DateTime?
  motivo_rechazo          String?
  consulta_cen            String?
  contenido_cen           String?
  respuesta_cen           String?

  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  last_activity_at DateTime?

  management   Management?        @relation(fields: [management_id], references: [id], onDelete: SetNull)
  mandante_rel Mandante?          @relation("MandanteTpRecords", fields: [mandante_id], references: [id], onDelete: SetNull)
  company_rel  Company?           @relation("CompanyTpRecords", fields: [company_id], references: [id], onDelete: SetNull)
  line_rel     ManagementLine?    @relation("LineTpRecords", fields: [line_id], references: [id], onDelete: SetNull)
  line_afp_rel ManagementLineAfp? @relation("LineAfpTpRecords", fields: [line_afp_id], references: [id], onDelete: SetNull)

  @@index([management_id])
  @@index([mandante_id])
  @@index([company_id])
  @@index([line_id])
  @@index([line_afp_id])
  @@map("tp_records")
}

model Document {
  id                String           @id @default(cuid())
  related_module    String
  related_record_id String
  management_id     String?
  category          DocumentCategory @default(OTRO)
  file_name         String
  file_url          String
  file_size         Int?
  mime_type         String?
  uploaded_by_id    String?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  uploadedBy User?       @relation("UploadedByUser", fields: [uploaded_by_id], references: [id], onDelete: SetNull)
  management Management? @relation(fields: [management_id], references: [id], onDelete: SetNull)

  @@index([related_module, related_record_id])
  @@index([management_id])
  @@index([category])
  @@map("documents")
}

model Note {
  id                String   @id @default(cuid())
  related_module    String
  related_record_id String
  management_id     String?
  content           String
  created_by_id     String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  createdBy  User?       @relation(fields: [created_by_id], references: [id], onDelete: SetNull)
  management Management? @relation(fields: [management_id], references: [id], onDelete: SetNull)

  @@index([related_module, related_record_id])
  @@index([management_id])
  @@map("notes")
}

model Activity {
  id                String    @id @default(cuid())
  related_module    String
  related_record_id String
  management_id     String?
  activity_type     String?
  status            String?
  description       String?
  due_date          DateTime?
  assigned_to_id    String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  assignedTo User?       @relation(fields: [assigned_to_id], references: [id], onDelete: SetNull)
  management Management? @relation(fields: [management_id], references: [id], onDelete: SetNull)

  @@index([related_module, related_record_id])
  @@index([management_id])
  @@map("activities")
}
